# Copy to .env (never commit!).

# Password used to log in. Keep it secret.
APP_PASSWORD=changeme

# Path to the JSON data file (relative to repo root, or absolute).
# The directory is created automatically. Default: data/shopping-list.json
# DATA_FILE=data/shopping-list.json

# Backend port.
PORT=4000

# Client dev server URL allowed by CORS.
CLIENT_ORIGIN=http://localhost:5173
