# Copy to .env (never commit). Most fields below are filled in by the
# `supabase start` command; copy the matching values from its output.

# --- Local Supabase stack -------------------------------------------------
# These are the four values printed by `supabase start` (or seen via
# `supabase status`). The defaults below match the keys that ship with
# the local CLI image and remain stable across reboots.
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- BFF secrets ----------------------------------------------------------
# Long random string used to sign guest tokens & admin-elevated tokens.
# Rotating it logs out every guest with an outstanding share link.
JWT_SECRET=change-me-to-a-long-random-string

# How long an admin keeps their elevated re-auth (in seconds).
ADMIN_REAUTH_TTL_SECONDS=300

# Synthetic email domain used when mapping a user-typed name to an
# auth.users email. Internal only — users never see this.
EMAIL_DOMAIN=shoppinglist.local

# --- Bootstrap admin (only used the first time the server boots) ---------
# When set, the server creates this admin if no admin exists yet.
# Remove from .env after the first run.
ADMIN_BOOTSTRAP_NAME=admin
ADMIN_BOOTSTRAP_PASSWORD=changeme

# --- HTTP -----------------------------------------------------------------
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
