{
  "name": "shopping-list-v3",
  "private": true,
  "version": "0.1.0",
  "description": "Offline-first shopping list PWA with admin-managed users, shareable per-list guest links, and a local Supabase backend behind a tiny Express BFF.",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm --workspace server run dev",
    "dev:client": "npm --workspace client run dev",
    "build": "npm --workspace server run build && npm --workspace client run build",
    "start": "npm --workspace server run start",
    "typecheck": "npm --workspace server run typecheck && npm --workspace client run typecheck",
    "supabase": "supabase",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:status": "supabase status",
    "supabase:reset": "supabase db reset",
    "prod": "scripts/prod.sh start",
    "prod:start": "scripts/prod.sh start",
    "prod:stop": "scripts/prod.sh stop",
    "prod:restart": "scripts/prod.sh restart",
    "prod:status": "scripts/prod.sh status",
    "prod:logs": "scripts/prod.sh logs",
    "redeploy": "scripts/redeploy.sh"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "supabase": "^2.98.2"
  }
}
